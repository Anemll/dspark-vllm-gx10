NODE_RANK=0
HEADLESS=
MASTER_ADDR=10.200.0.1
MASTER_PORT=25000
VLLM_HOST_IP=10.200.0.1

NCCL_IB_HCA=CHANGEME_RDMA_DEVICE
NCCL_SOCKET_IFNAME=CHANGEME_FABRIC_INTERFACE
TP_SOCKET_IFNAME=CHANGEME_FABRIC_INTERFACE
GLOO_SOCKET_IFNAME=CHANGEME_FABRIC_INTERFACE

DSPARK_VLLM_IMAGE=ghcr.io/anemll/dspark-vllm-gx10:0.1.1
DSPARK_MODEL_HOST=/srv/dspark/models/DeepSeek-V4-Flash-DSpark-Abliterated-Uncensored
# May differ from DSPARK_MODEL_HOST for a prepared NVFP4 target. The in-container
# draft path remains /models/dspark-draft on both ranks.
DSPARK_DRAFT_MODEL_HOST=/srv/dspark/models/DeepSeek-V4-Flash-DSpark-Abliterated-Uncensored
HF_CACHE=/srv/dspark/hf-cache
DSPARK_TMP_HOST=/var/lib/dspark-tmp
SERVED_MODEL_NAME=deepseek-v4-flash-dspark-abliterated

# Reversible opt-in: use direct_timed on both nodes for the synchronized local
# A/B baseline, or roce_tp on both nodes for rank-0-only checkpoint reads. Set
# this back to auto to restore the production local-loader path.
DSPARK_WEIGHT_LOAD_FORMAT=auto
# Keep both ranks identical. Compare flashinfer_cutlass and flashinfer_b12x
# with the matched NVFP4 hardware matrix before changing the default.
DSPARK_MOE_BACKEND=flashinfer_b12x
DSPARK_B12X_MICRO_MAX_ACTIVE_CLUSTERS=40
# Reversible experimental loader gate.  Production remains on the ordinary
# vLLM loader until an exact NVIDIA NVFP4 candidate passes the cold-load screen.
VLLM_DSV4_NVFP4_LAYER_STAGED_LOAD=0
# Incompatible offline-prepared checkpoint path. Keep disabled and its pin
# empty unless the exact prepared artifact and immutable candidate are used.
VLLM_DSV4_NVFP4_CUTLASS_PREPARED_LOAD=0
VLLM_DSV4_NVFP4_CUTLASS_PREPARED_MANIFEST_SHA256=
VLLM_DSV4_NVFP4_CUTLASS_PREPARED_DIRECT_READ=1
DSPARK_ROCE_LOAD_BUFFER_MB=256

MAX_MODEL_LEN=350000
MAX_NUM_SEQS=12
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.78
# Optional exact per-rank KV allocation. Leave empty for the normal
# gpu-memory-utilization calculation. The NVFP4+DSpark validation profile uses
# 32212254720 (30 GiB) after its fail-closed hardware projection passes.
KV_CACHE_MEMORY_BYTES=
# Must match both ranks. `dspark` enables the draft layers and expands the CUDA
# graph ceiling; `off` runs target-only. Any other value fails startup.
DSPARK_SPECULATION_MODE=dspark
MTP_NUM_TOKENS=5
# Released production parity. Confidence-enabled tuning is a separate matched
# experiment and must change these identically on both ranks.
VLLM_DSPARK_CONFIDENCE_SCHEDULER=off
VLLM_DSPARK_CONFIDENCE_THRESHOLD=0.0
# `warn` is the serving default; use `error` only for cold-start validation.
JIT_MONITOR_MODE=warn
# JIT_MONITOR_VERBOSE=1

# Optional cluster launcher settings.
WORKER_SSH=CHANGEME_USER@10.200.0.2
WORKER_REPO_DIR=/srv/dspark/dspark-vllm-gx10
