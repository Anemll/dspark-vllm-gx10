NODE_RANK=1
HEADLESS=1
MASTER_ADDR=10.200.0.1
MASTER_PORT=25000
VLLM_HOST_IP=10.200.0.2

NCCL_IB_HCA=CHANGEME_RDMA_DEVICE
NCCL_SOCKET_IFNAME=CHANGEME_FABRIC_INTERFACE
TP_SOCKET_IFNAME=CHANGEME_FABRIC_INTERFACE
GLOO_SOCKET_IFNAME=CHANGEME_FABRIC_INTERFACE

DSPARK_VLLM_IMAGE=ghcr.io/anemll/dspark-vllm-gx10:0.1.1
DSPARK_MODEL_HOST=/srv/dspark/models/DeepSeek-V4-Flash-DSpark-Abliterated-Uncensored
HF_CACHE=/srv/dspark/hf-cache
DSPARK_TMP_HOST=/var/lib/dspark-tmp
SERVED_MODEL_NAME=deepseek-v4-flash-dspark-abliterated

# Must match the head node. direct_timed measures unchanged local reads with a
# synchronized boundary; roce_tp reads metadata locally and receives this
# rank's exact TP weight writes through the NCCL/RoCE fabric.
DSPARK_WEIGHT_LOAD_FORMAT=auto
DSPARK_ROCE_LOAD_BUFFER_MB=64
# Must match the head configuration. Reclaim itself is sender-only.
DSPARK_ROCE_RELEASE_WATERMARK_MB=1024

MAX_MODEL_LEN=350000
MAX_NUM_SEQS=12
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.78
MTP_NUM_TOKENS=5
# `warn` is the serving default; use `error` only for cold-start validation.
JIT_MONITOR_MODE=warn
# JIT_MONITOR_VERBOSE=1
