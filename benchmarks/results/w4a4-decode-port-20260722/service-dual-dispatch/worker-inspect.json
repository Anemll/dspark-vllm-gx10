d DSPARK_SPECULATION_MODE=%q; expected dspark or off\\n' \"${DSPARK_SPECULATION_MODE}\" >&2;\n    exit 64;\n    ;;\nesac; exec /usr/local/bin/vllm serve /models/dsv4-abliterated --served-model-name deepseek-v4-flash-nvfp4-dual-target-only --host 0.0.0.0 --port 8888 --trust-remote-code --load-format \"${DSPARK_WEIGHT_LOAD_FORMAT:-auto}\" --model-loader-extra-config \"${MODEL_LOADER_EXTRA_CONFIG}\" --tensor-parallel-size 2 --pipeline-parallel-size 1 --kv-cache-dtype nvfp4_ds_mla --block-size 256 --max-model-len 65536 --max-num-seqs 12 --max-num-batched-tokens 8192 --max-cudagraph-capture-size \"${MAX_CUDAGRAPH_CAPTURE_SIZE}\" --gpu-memory-utilization 0.83 \"${KV_CACHE_ARGS[@]}\" \"${PROFILER_ARGS[@]}\" --enable-prefix-caching --async-scheduling --enable-chunked-prefill \"${SPECULATIVE_ARGS[@]}\" --tokenizer-mode deepseek_v4 --distributed-executor-backend mp --moe-backend flashinfer_cutlass --tool-call-parser deepseek_v4 --enable-auto-tool-choice --reasoning-parser deepseek_v4 --reasoning-config '{\"reasoning_parser\":\"deepseek_v4\",\"reasoning_start_str\":\"<think>\",\"reasoning_end_str\":\"</think>\"}' --default-chat-template-kwargs '{\"thinking\":false}' --generation-config vllm --enable-flashinfer-autotune --nnodes 2 --node-rank 1 --master-addr 10.200.0.1 --master-port 25000 --jit-monitor-mode warn --jit-monitor-verbose --headless\n"
