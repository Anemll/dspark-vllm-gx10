# SPDX-License-Identifier: MIT
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG SOURCE_REVISION=unknown

COPY scripts/patch_vllm_b12x_output_alias.py \
  /usr/local/bin/dspark-patch-vllm-b12x-output-alias

RUN python3 /usr/local/bin/dspark-patch-vllm-b12x-output-alias

COPY overlay/vllm/ /usr/local/lib/python3.12/dist-packages/vllm/
COPY benchmarks/benchmark_nvfp4_a4w4_sm121.py \
  /usr/local/bin/dspark-benchmark-nvfp4-a4w4-sm121
COPY benchmarks/benchmark_nvfp4_prepared_b12x_sm121.py \
  /usr/local/bin/dspark-benchmark-nvfp4-prepared-b12x-sm121

RUN python3 -m py_compile \
      /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/modular_kernel.py \
      /usr/local/lib/python3.12/dist-packages/vllm/models/deepseek_v4/quant_config.py \
      /usr/local/lib/python3.12/dist-packages/vllm/models/deepseek_v4/nvidia/prepared_weight_loading.py \
      /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/experts/flashinfer_b12x_moe.py \
      /usr/local/bin/dspark-benchmark-nvfp4-a4w4-sm121 \
      /usr/local/bin/dspark-benchmark-nvfp4-prepared-b12x-sm121

LABEL org.opencontainers.image.revision="${SOURCE_REVISION}"
LABEL org.opencontainers.image.nvfp4-b12x-decode="direct-output-alias-v1"
