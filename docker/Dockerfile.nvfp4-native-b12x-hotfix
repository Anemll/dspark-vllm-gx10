ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG BASE_IMAGE
ARG BASE_IMAGE_ID
ARG SOURCE_REVISION

RUN python3 -c 'import re, sys; assert re.fullmatch(r"[0-9a-f]{40}", sys.argv[1]); assert sys.argv[2] == "sha256:da0ef9bf64df7a6e49e152e0c4f8f8bb82d0752851f975074f182ec635743795"' \
      "${SOURCE_REVISION}" "${BASE_IMAGE_ID}"

# Layer only the native-B12X selection and prepared-loader integration over
# the already validated ABI-coherent SM121/B12X image.  No package install,
# network access, or kernel rebuild is permitted.
COPY overlay/vllm/envs.py \
  /usr/local/lib/python3.12/dist-packages/vllm/envs.py
COPY overlay/vllm/model_executor/layers/fused_moe/oracle/nvfp4.py \
  /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/oracle/nvfp4.py
COPY overlay/vllm/model_executor/layers/fused_moe/experts/nvfp4_dual_decode_moe.py \
  /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/experts/nvfp4_dual_decode_moe.py
COPY overlay/vllm/models/deepseek_v4/nvidia/prepared_weight_loading.py \
  /usr/local/lib/python3.12/dist-packages/vllm/models/deepseek_v4/nvidia/prepared_weight_loading.py

RUN python3 -m py_compile \
      /usr/local/lib/python3.12/dist-packages/vllm/envs.py \
      /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/oracle/nvfp4.py \
      /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/experts/nvfp4_dual_decode_moe.py \
      /usr/local/lib/python3.12/dist-packages/vllm/models/deepseek_v4/nvidia/prepared_weight_loading.py

LABEL org.opencontainers.image.revision="${SOURCE_REVISION}" \
      org.opencontainers.image.base.name="${BASE_IMAGE}" \
      org.opencontainers.image.base.digest="${BASE_IMAGE_ID}" \
      org.opencontainers.image.nvfp4-native-b12x="packed-w4a16-all-phase-v1"

