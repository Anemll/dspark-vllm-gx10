ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG SOURCE_REVISION=unknown
ARG BASE_V2_MODEL_RUNNER_SHA256=61befb32cdc06e1c58383f9481e805d3b86637c84736f79b904c04a474df34e4
ARG ROUTE_V2_MODEL_RUNNER_SHA256=66e484fc86ed0230fcd5e2b49040b0c388e99c6725ae5d93976cb421f0cd8b1a
ARG TARGET_ROUTE_CAPTURE_SHA256=12bce7402c3160af8b0116335e174e14cb7217abd4ade8b7b24e4cd8a770b1aa

# This diagnostic image intentionally starts from the accepted W4A4 dual-
# dispatch service image. Refuse a different runner instead of applying the
# overlay to an unknown serving path.
RUN echo "${BASE_V2_MODEL_RUNNER_SHA256}  /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/model_runner.py" | sha256sum -c -

COPY overlay/vllm/v1/worker/gpu/model_runner.py /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/model_runner.py
COPY overlay/vllm/v1/worker/gpu/target_route_capture.py /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/target_route_capture.py

RUN echo "${ROUTE_V2_MODEL_RUNNER_SHA256}  /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/model_runner.py" | sha256sum -c - && \
    echo "${TARGET_ROUTE_CAPTURE_SHA256}  /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/target_route_capture.py" | sha256sum -c - && \
    python3 -m py_compile \
      /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/model_runner.py \
      /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/target_route_capture.py

LABEL org.opencontainers.image.revision="${SOURCE_REVISION}"
LABEL org.opencontainers.image.dspark-target-route-capture="target-only-c4-v1"
LABEL org.opencontainers.image.dspark-target-route-model-runner-sha256="${ROUTE_V2_MODEL_RUNNER_SHA256}"
LABEL org.opencontainers.image.dspark-target-route-helper-sha256="${TARGET_ROUTE_CAPTURE_SHA256}"
