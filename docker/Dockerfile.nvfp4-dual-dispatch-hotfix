ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG BASE_IMAGE
ARG BASE_IMAGE_ID
ARG SOURCE_REVISION

RUN python3 -c 'import re, sys; assert re.fullmatch(r"[0-9a-f]{40}", sys.argv[1]); assert sys.argv[2] == "sha256:c018a6b967af6a6d6d2e415fc6fe54b9f4eecf4d72d95dc956bffbca7f88f848"' \
