  /usr/local/lib/python3.12/dist-packages/vllm/models/deepseek_v4/nvidia/prepared_weight_loading.py

RUN printf '%s  %s\n' \
      '61befb32cdc06e1c58383f9481e805d3b86637c84736f79b904c04a474df34e4' \
      '/usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu/model_runner.py' \
